# ──────────────────────────────────────────────────────────
# InternHub — Environment Variables
# Copy this file to `.env` and fill in your real credentials.
# NEVER commit `.env` to version control.
# ──────────────────────────────────────────────────────────

# ── Groq LLM ──────────────────────────────────────────────
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile

# ── PostgreSQL Database ───────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=internhub
DB_USER=postgres
DB_PASSWORD=Raj@2006

# ── ChromaDB (local vector store) ────────────────────────
CHROMA_PATH=./chroma_db

# ── JWT Authentication ────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_replace_with_a_strong_random_secret
JWT_ALGORITHM=HS256

# ── CORS ──────────────────────────────────────────────────
# For local dev: http://localhost:3000
# For prod: https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Server ────────────────────────────────────────────────
PORT=8000
